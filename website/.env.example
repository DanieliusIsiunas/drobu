# Build-time environment variables for the Drobu website.
# Copy to .env (gitignored) for local dev, or set as repository
# variables / secrets for the GitHub Actions deploy workflow.
#
# Astro exposes any PUBLIC_* var to the client bundle at build time.

# Stripe Checkout / Payment Link URL used by every "Start free trial" CTA.
# When omitted, src/config.ts falls back to the test URL.
PUBLIC_STRIPE_CHECKOUT_URL=https://buy.stripe.com/test_3cI3cu1YJ8tDeRMbOCcwg00
