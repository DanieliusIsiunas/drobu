---
/**
 * Honest media frame for real Drobu captures.
 *
 * Drobu's surface is a floating panel, NOT a Mac window, so this deliberately
 * does NOT wrap media in a Mac-window frame (no traffic-light chrome). It
 * presents a real screenshot / screen recording as a clean floating "screen":
 * rounded corners, a hairline border, and a soft shadow so it lifts off the page.
 *
 * Handles both stills/GIFs (rendered as <img>, lazy) and video (.mp4/.webm,
 * rendered as a muted looping <video> with a poster for instant first paint;
 * playback is started by JS only when motion is welcome, so reduced-motion and
 * no-JS visitors rest on the poster, enforced at markup time).
 *
 * Motion accessibility (WCAG 2.2.2: any autoplaying loop longer than a few
 * seconds needs a stop mechanism for ALL visitors, not only reduced-motion ones):
 *  - Video AND GIF showcases get an always-visible pause/play toggle. Video uses
 *    the media API; a GIF (no playback API) is frozen by swapping its <img> to the
 *    static still and back.
 *  - Both default to the still/poster in the markup, so reduced-motion AND no-JS
 *    visitors get no motion at all. JS opts into the animation only when motion is
 *    welcome; the toggle then swaps between still and motion for everyone.
 *
 * Media is self-hosted (public/media) to fit the no-CDN privacy stance. Pass
 * intrinsic width/height so the browser reserves space (no layout shift).
 */
interface Props {
  /** Path under /media, e.g. "/media/main-interface.mp4" or "/media/image-crop.gif" */
  src: string;
  /** What the capture shows, for screen readers */
  alt: string;
  /** Intrinsic pixel dimensions of the asset (for aspect ratio + no CLS) */
  width: number;
  height: number;
  /** Poster image for video: the LCP frame and the reduced-motion still */
  poster?: string;
  /** Static still for a GIF: the default frame shipped in the markup (no motion
   *  without JS) and the paused frame. Required to animate/pause a GIF. */
  still?: string;
  class?: string;
}

const { src, alt, width, height, poster, still, class: className = "" } = Astro.props;
const isVideo = /\.(mp4|webm)$/.test(src);
const videoType = src.endsWith(".webm") ? "video/webm" : "video/mp4";
// A GIF can only be paused if we have a still to freeze it on.
const pausableGif = !isVideo && !!still;
const showcaseKind = isVideo ? "video" : pausableGif ? "gif" : undefined;
---

<figure
  class:list={["relative m-0 rounded-xl overflow-hidden border border-white/10 bg-bg-elevated shadow-2xl", className]}
  data-showcase={showcaseKind}
>
  {isVideo ? (
    <video
      class="block w-full h-auto"
      width={width}
      height={height}
      muted
      loop
      playsinline
      preload="auto"
      poster={poster}
      aria-label={alt}
    >
      <source src={src} type={videoType} />
    </video>
  ) : (
    <img
      src={pausableGif ? still : src}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="block w-full h-auto"
      data-animated={pausableGif ? src : undefined}
      data-still={pausableGif ? still : undefined}
    />
  )}

  {showcaseKind && (
    <button
      type="button"
      class="showcase-toggle absolute bottom-3 right-3 grid place-items-center w-9 h-9 rounded-full bg-black/55 text-white backdrop-blur transition-colors hover:bg-black/75 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/80"
      aria-label="Pause the demo"
      aria-pressed="false"
    >
      <svg class="icon-pause" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <rect x="6" y="5" width="4" height="14" rx="1" /><rect x="14" y="5" width="4" height="14" rx="1" />
      </svg>
      <svg class="icon-play" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M8 5v14l11-7z" />
      </svg>
    </button>
  )}
</figure>

<style>
  .showcase-toggle .icon-play { display: none; }
  .showcase-toggle.is-paused .icon-pause { display: none; }
  .showcase-toggle.is-paused .icon-play { display: block; }
</style>

<script>
  // Wire each showcase's pause/play toggle (WCAG 2.2.2). Video uses the media
  // API; a GIF is frozen by swapping its <img> to the static still and back.
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  for (const fig of document.querySelectorAll("[data-showcase]")) {
    const kind = fig.getAttribute("data-showcase");
    const btn = fig.querySelector(".showcase-toggle");
    if (!(btn instanceof HTMLButtonElement)) continue;

    const reflect = (paused: boolean) => {
      btn.classList.toggle("is-paused", paused);
      btn.setAttribute("aria-label", paused ? "Play the demo" : "Pause the demo");
      btn.setAttribute("aria-pressed", String(paused));
    };

    if (kind === "video") {
      const video = fig.querySelector("video");
      if (!(video instanceof HTMLVideoElement)) continue;
      btn.addEventListener("click", () => {
        if (video.paused) video.play();
        else video.pause();
      });
      video.addEventListener("play", () => reflect(false));
      video.addEventListener("pause", () => reflect(true));
      // No autoplay attribute: reduced-motion and no-JS visitors rest on the
      // poster (enforced at markup time). Start playback only when motion is welcome.
      if (reduceMotion) {
        reflect(true);
      } else {
        video.play().catch(() => reflect(true));
      }
    } else if (kind === "gif") {
      const img = fig.querySelector("img");
      if (!(img instanceof HTMLImageElement)) continue;
      const animated = img.dataset.animated;
      const still = img.dataset.still;
      if (!animated || !still) continue;
      // Markup ships the still (no motion without JS). Start animating only when
      // motion is welcome; the toggle swaps between still and animated for all.
      let paused = reduceMotion;
      if (!paused) img.src = animated;
      reflect(paused);
      btn.addEventListener("click", () => {
        paused = !paused;
        img.src = paused ? still : animated;
        reflect(paused);
      });
    }
  }
</script>
