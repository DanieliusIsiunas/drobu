---
interface Props {
  title: string;
  description: string;
  size?: "medium" | "large";
  class?: string;
}

const { title, description, size = "medium", class: className = "" } = Astro.props;

const sizeClasses = {
  medium: "md:col-span-1",
  large: "md:col-span-2",
};
---

<div class:list={[
  "group relative rounded-2xl border border-white/5 bg-bg-card p-6 overflow-hidden",
  "hover:border-white/10 hover:-translate-y-1 hover:shadow-lg",
  "transition-all duration-300 ease-out",
  sizeClasses[size],
  className,
]}>
  <!-- Visual mockup area -->
  <div class="aspect-video rounded-lg bg-bg-elevated mb-5 flex items-center justify-center overflow-hidden">
    <slot />
  </div>

  <h3 class="text-lg font-semibold text-text-primary mb-1">{title}</h3>
  <p class="text-sm text-text-secondary leading-relaxed">{description}</p>
</div>
