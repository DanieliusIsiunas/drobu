---
const year = new Date().getFullYear();
---

<footer class="py-12 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
    <p>Built with Swift & SwiftUI &middot; &copy; {year}</p>
    <div class="flex items-center gap-6">
      <a
        href="https://github.com/DanieliusIsiunas/clipboard-history"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-text-secondary transition-colors"
      >
        GitHub
      </a>
      <span>v1.0</span>
    </div>
  </div>
</footer>
