---
import Showcase from "./Showcase.astro";
import { DOWNLOAD_URL } from "../config";
---

<section class="relative pt-32 pb-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col items-center text-center mb-16">
      <img
        src="/drobule.png"
        alt="Drobu mascot"
        width="96"
        height="96"
        class="mb-6"
      />
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-text-primary max-w-3xl leading-[1.1]">
        Your Mac clipboard, captured. Edited.&nbsp;<span class="text-accent">Pasted.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-text-secondary max-w-2xl">
        Everything you copy lands in a searchable clipboard history: text, images, GIFs, files, even a screen recording. Crop, trim, and clean any of it right in the panel, then paste one item or a whole stack with one keystroke.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
        <a
          href={DOWNLOAD_URL}
          download="Drobu.dmg"
          class="js-app-download inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-base"
          id="download-cta"
        >
          <span class="download-label">Download Free Trial</span>
        </a>
      </div>
    </div>

    <!-- Primary hero visual: the real Drobu interface, autoplay muted loop. -->
    <Showcase
      src="/media/main-interface.mp4"
      poster="/media/main-interface.jpg"
      alt="The Drobu clipboard panel: search the history, filter by type, preview a clip, and paste"
      width={1064}
      height={634}
      class="max-w-4xl mx-auto"
    />
  </div>
</section>
