---
import MacWindow from "./MacWindow.astro";
import { DOWNLOAD_URL } from "../config";
---

<section class="relative pt-32 pb-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col items-center text-center mb-16">
      <img
        src="/drobule.png"
        alt="Drobu mascot"
        width="96"
        height="96"
        class="mb-6"
      />
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-text-primary max-w-3xl leading-[1.1]">
        Your Mac clipboard, captured. Edited.&nbsp;<span class="text-accent">Pasted.</span>
      </h1>
      <p class="mt-6 text-lg md:text-xl text-text-secondary max-w-xl">
        Copy anything or record your screen. Trim it, then paste it all with one keystroke. No app switching. No file management.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
        <a
          href={DOWNLOAD_URL}
          download="Drobu.dmg"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-base"
          id="download-cta"
        >
          <span class="download-label">Download Free Trial</span>
        </a>
      </div>

      <p class="mt-4 text-sm text-text-muted">
        Free for 14 days, then $14.99 once &middot; no subscription &middot; macOS 14+
      </p>
    </div>

    <!-- Hero visual: recording a region of the screen (the differentiator) -->
    <MacWindow title="Drobu" class="max-w-3xl mx-auto">
      <div class="relative bg-bg-primary overflow-hidden" style="aspect-ratio: 16 / 9;" id="hero-media">
        <!-- Faux desktop content being recorded -->
        <div class="absolute inset-0 p-6 opacity-25 select-none" aria-hidden="true">
          <div class="h-3 w-44 rounded bg-white/15 mb-4"></div>
          <div class="h-2.5 w-3/4 rounded bg-white/10 mb-2.5"></div>
          <div class="h-2.5 w-2/3 rounded bg-white/10 mb-2.5"></div>
          <div class="h-2.5 w-1/2 rounded bg-white/10"></div>
          <div class="mt-6 grid grid-cols-3 gap-3 max-w-md">
            <div class="h-16 rounded-lg bg-white/5"></div>
            <div class="h-16 rounded-lg bg-white/5"></div>
            <div class="h-16 rounded-lg bg-white/5"></div>
          </div>
        </div>

        <!-- Region selection -->
        <div class="absolute" style="left: 16%; top: 20%; right: 20%; bottom: 26%;" aria-hidden="true">
          <div class="absolute inset-0 rounded-md border-2 border-dashed border-accent/80 bg-accent/5"></div>
          <span class="absolute -top-px -left-px w-4 h-4 border-t-2 border-l-2 border-accent"></span>
          <span class="absolute -top-px -right-px w-4 h-4 border-t-2 border-r-2 border-accent"></span>
          <span class="absolute -bottom-px -left-px w-4 h-4 border-b-2 border-l-2 border-accent"></span>
          <span class="absolute -bottom-px -right-px w-4 h-4 border-b-2 border-r-2 border-accent"></span>
        </div>

        <!-- Capture control bar -->
        <div class="absolute left-1/2 -translate-x-1/2 bottom-4 flex items-center gap-2.5 px-3.5 py-2 rounded-full bg-bg-card/95 border border-white/10 shadow-xl">
          <span class="hero-rec inline-block w-2.5 h-2.5 rounded-full bg-red-500"></span>
          <span class="text-xs font-mono text-text-primary">0:04</span>
          <span class="w-px h-3.5 bg-white/10"></span>
          <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-accent/20 text-accent font-medium">GIF</span>
          <span class="text-[10px] text-text-muted">Capture &rarr; Trim &rarr; Paste</span>
        </div>
      </div>
    </MacWindow>
  </div>
</section>

<style>
  @keyframes heroRecPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.35; transform: scale(0.75); }
  }
  .hero-rec {
    animation: heroRecPulse 1.4s ease-in-out infinite;
  }
</style>

<script>
  // Platform detection: disable CTA for non-macOS visitors
  const label = document.querySelector(".download-label");
  const cta = document.getElementById("download-cta");
  if (label && cta) {
    const isMac = navigator.platform?.includes("Mac") ||
      (navigator as any).userAgentData?.platform === "macOS";
    if (!isMac) {
      label.textContent = "macOS only";
      cta.setAttribute("href", "#");
      cta.classList.remove("bg-accent", "hover:bg-accent-hover");
      cta.classList.add("bg-white/10", "cursor-not-allowed", "opacity-60");
    }
  }
</script>
