---
import MacWindow from "./MacWindow.astro";
---

<section class="relative pt-32 pb-20 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col items-center text-center mb-16">
      <img
        src="/clipboard-history/drobule.png"
        alt="Drobu mascot"
        width="96"
        height="96"
        class="mb-6"
      />
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-text-primary max-w-3xl leading-[1.1]">
        Your clipboard, with a&nbsp;<span class="text-accent">memory</span>.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-text-secondary max-w-xl">
        Drobu keeps everything you copy — text, images, GIFs, videos, files — and lets you find it instantly. Search, preview, paste — in one keystroke.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
        <a
          href="https://buy.stripe.com/test_3cI3cu1YJ8tDeRMbOCcwg00"
          class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-base"
          id="download-cta"
        >
          <span class="download-label">Start free trial</span>
        </a>
      </div>

      <p class="mt-4 text-sm text-text-muted">
        $9.99/mo after 14-day free trial &middot; macOS 14+ &middot; Cancel anytime
      </p>
    </div>

    <!-- App preview — CSS mockup of the actual Drobu panel UI -->
    <MacWindow title="Drobu" class="max-w-3xl mx-auto">
      <div class="bg-bg-primary" id="hero-media">
        <!-- Search bar -->
        <div class="flex items-center gap-2 px-3 py-2.5 border-b border-white/5">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-muted shrink-0">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
          <span class="text-sm text-text-muted">Search clipboard...</span>
        </div>

        <!-- Filter tabs -->
        <div class="flex items-center gap-1 px-3 py-1.5 border-b border-white/5">
          <span class="text-xs px-2 py-0.5 rounded-full bg-accent/20 text-accent font-medium">All</span>
          <span class="text-xs px-2 py-0.5 rounded-full text-text-muted">Text</span>
          <span class="text-xs px-2 py-0.5 rounded-full text-text-muted">Image</span>
          <span class="text-xs px-2 py-0.5 rounded-full text-text-muted">GIF</span>
          <span class="text-xs px-2 py-0.5 rounded-full text-text-muted">Video</span>
          <span class="text-xs px-2 py-0.5 rounded-full text-text-muted">File</span>
        </div>

        <!-- Split panel: list | preview -->
        <div class="flex" style="min-height: 220px;">
          <!-- Left: clipboard list -->
          <div class="w-[45%] border-r border-white/5">
            <!-- Row 1 — selected -->
            <div class="flex items-center gap-2 px-2.5 py-1.5 bg-accent/15">
              <div class="w-4 h-4 rounded bg-[#1a8cff] shrink-0 flex items-center justify-center">
                <span class="text-[8px] text-white font-bold">S</span>
              </div>
              <span class="text-xs text-text-primary truncate flex-1">https://developer.apple.com/sf-symbols</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;1</kbd>
            </div>
            <!-- Row 2 -->
            <div class="flex items-center gap-2 px-2.5 py-1.5">
              <div class="w-4 h-4 rounded bg-[#8b5cf6] shrink-0 flex items-center justify-center">
                <span class="text-[8px] text-white font-bold">C</span>
              </div>
              <span class="text-xs text-text-secondary truncate flex-1">func extractRecord(from item:...</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;2</kbd>
            </div>
            <!-- Row 3 -->
            <div class="flex items-center gap-2 px-2.5 py-1.5">
              <div class="w-4 h-4 rounded bg-[#f59e0b] shrink-0 flex items-center justify-center">
                <span class="text-[8px] text-white font-bold">N</span>
              </div>
              <span class="text-xs text-text-secondary truncate flex-1">Meeting notes — Q2 planning</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;3</kbd>
            </div>
            <!-- Row 4 — image -->
            <div class="flex items-center gap-2 px-2.5 py-1.5">
              <div class="w-4 h-4 rounded bg-[#22c55e] shrink-0 flex items-center justify-center">
                <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor" class="text-white"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
              </div>
              <span class="text-xs text-text-secondary truncate flex-1">Image: 1920×1080 (245 KB)</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;4</kbd>
            </div>
            <!-- Row 5 -->
            <div class="flex items-center gap-2 px-2.5 py-1.5">
              <div class="w-4 h-4 rounded bg-[#ef4444] shrink-0 flex items-center justify-center">
                <span class="text-[8px] text-white font-bold">F</span>
              </div>
              <span class="text-xs text-text-secondary truncate flex-1">GIF: 640×480 (1.2 MB, 3.2s)</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;5</kbd>
            </div>
            <!-- Row 6 -->
            <div class="flex items-center gap-2 px-2.5 py-1.5">
              <div class="w-4 h-4 rounded bg-[#06b6d4] shrink-0 flex items-center justify-center">
                <span class="text-[8px] text-white font-bold">T</span>
              </div>
              <span class="text-xs text-text-secondary truncate flex-1">/Users/dan/Desktop/screenshot.png</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;6</kbd>
            </div>
            <!-- Row 7 -->
            <div class="flex items-center gap-2 px-2.5 py-1.5">
              <div class="w-4 h-4 rounded bg-[#8b5cf6] shrink-0 flex items-center justify-center">
                <span class="text-[8px] text-white font-bold">C</span>
              </div>
              <span class="text-xs text-text-secondary truncate flex-1">SELECT * FROM users WHERE...</span>
              <kbd class="text-[9px] text-text-muted bg-white/5 px-1 rounded font-mono">&#8984;7</kbd>
            </div>
          </div>

          <!-- Right: preview panel -->
          <div class="flex-1 flex flex-col p-3">
            <div class="flex-1 flex flex-col justify-center">
              <p class="text-xs text-accent mb-1 font-medium">Safari</p>
              <p class="text-sm text-text-primary leading-relaxed break-all">https://developer.apple.com/sf-symbols</p>
              <p class="text-xs text-text-muted mt-3 leading-relaxed">SF Symbols provides a set of over 6,000 consistent, highly configurable symbols you can use in your app...</p>
            </div>
            <!-- Metadata bar -->
            <div class="flex items-center justify-between pt-2 mt-2 border-t border-white/5">
              <span class="text-[10px] text-text-muted">from Safari &middot; 2 min ago</span>
              <span class="text-[10px] text-text-muted">text &middot; 48 chars</span>
            </div>
          </div>
        </div>
      </div>
    </MacWindow>
  </div>
</section>

<script>
  // Platform detection: disable CTA for non-macOS visitors
  const label = document.querySelector(".download-label");
  const cta = document.getElementById("download-cta");
  if (label && cta) {
    const isMac = navigator.platform?.includes("Mac") ||
      (navigator as any).userAgentData?.platform === "macOS";
    if (!isMac) {
      label.textContent = "macOS only";
      cta.setAttribute("href", "#");
      cta.classList.remove("bg-accent", "hover:bg-accent-hover");
      cta.classList.add("bg-white/10", "cursor-not-allowed", "opacity-60");
    }
  }
</script>
