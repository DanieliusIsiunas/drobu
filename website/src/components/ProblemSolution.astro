---
---

<section class="py-24 px-6">
  <div class="max-w-4xl mx-auto">

    <!-- CSS-only tabs via hidden radio inputs -->
    <div class="problem-solution">
      <!-- Radio inputs (hidden, drive state) -->
      <input type="radio" name="journey" id="j-video" class="sr-only peer/video" checked />
      <input type="radio" name="journey" id="j-gif" class="sr-only peer/gif" />
      <input type="radio" name="journey" id="j-text" class="sr-only peer/text" />
      <input type="radio" name="journey" id="j-multi" class="sr-only peer/multi" />

      <!-- Tab pills -->
      <div class="flex items-center justify-center gap-2 mb-12">
        <label for="j-video" class="journey-tab">Video</label>
        <label for="j-gif" class="journey-tab">GIF</label>
        <label for="j-text" class="journey-tab">Text</label>
        <label for="j-multi" class="journey-tab">Multi-paste</label>
      </div>

      <!-- Story panels -->
      <div class="relative">

        <!-- Video story -->
        <div class="journey-panel" data-journey="video">
          <div class="grid md:grid-cols-2 gap-12 md:gap-16">
            <div>
              <p class="text-xs uppercase tracking-widest text-text-muted mb-5">The old way</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">1.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Open QuickTime</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">2.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Record your screen</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">3.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Stop and save the file</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">4.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Open Finder, locate it</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">5.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Drag into the other app</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">6.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Delete the leftover file</span></div>
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-accent mb-5">With Drobu</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">1.</span><span class="text-lg font-semibold text-text-primary">Capture region</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">2.</span><span class="text-lg font-semibold text-text-primary">Trim</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">3.</span><span class="text-lg font-semibold text-text-primary">Paste</span></div>
              </div>
              <p class="mt-5 text-text-secondary text-base">No QuickTime. No file management. Screen to clipboard in one flow.</p>
            </div>
          </div>
        </div>

        <!-- GIF story -->
        <div class="journey-panel" data-journey="gif">
          <div class="grid md:grid-cols-2 gap-12 md:gap-16">
            <div>
              <p class="text-xs uppercase tracking-widest text-text-muted mb-5">The old way</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">1.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Record your screen</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">2.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Open a GIF converter</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">3.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Import the video file</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">4.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Trim and adjust settings</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">5.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Export as GIF</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">6.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Upload or drag to app</span></div>
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-accent mb-5">With Drobu</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">1.</span><span class="text-lg font-semibold text-text-primary">Capture region</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">2.</span><span class="text-lg font-semibold text-text-primary">Trim frames</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">3.</span><span class="text-lg font-semibold text-text-primary">Paste</span></div>
              </div>
              <p class="mt-5 text-text-secondary text-base">Straight to GIF. Trim it frame by frame, paste into Slack or GitHub. Done.</p>
            </div>
          </div>
        </div>

        <!-- Text story -->
        <div class="journey-panel" data-journey="text">
          <div class="grid md:grid-cols-2 gap-12 md:gap-16">
            <div>
              <p class="text-xs uppercase tracking-widest text-text-muted mb-5">The old way</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">1.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Copy from terminal</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">2.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Paste into a text editor</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">3.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Strip ANSI color codes</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">4.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Fix the hard wrapping</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">5.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Copy the clean version</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">6.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Paste where you need it</span></div>
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-accent mb-5">With Drobu</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">1.</span><span class="text-lg font-semibold text-text-primary">Copy</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">2.</span><span class="text-lg font-semibold text-text-primary">Paste</span></div>
              </div>
              <p class="mt-5 text-text-secondary text-base">ANSI codes stripped. Hard wraps cleaned. Terminal output becomes clean text automatically.</p>
            </div>
          </div>
        </div>

        <!-- Multi-paste story -->
        <div class="journey-panel" data-journey="multi">
          <div class="grid md:grid-cols-2 gap-12 md:gap-16">
            <div>
              <p class="text-xs uppercase tracking-widest text-text-muted mb-5">The old way</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">1.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Copy first item</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">2.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Switch apps, paste</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">3.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Switch back, copy second</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">4.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Switch apps, paste</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">5.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Switch back, copy third</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-text-muted w-4 text-right">6.</span><span class="text-lg text-text-secondary line-through decoration-text-muted/50">Switch apps, paste</span></div>
              </div>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-accent mb-5">With Drobu</p>
              <div class="space-y-2.5">
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">1.</span><span class="text-lg font-semibold text-text-primary">Copy all three</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">2.</span><span class="text-lg font-semibold text-text-primary">Select all</span></div>
                <div class="flex items-center gap-3"><span class="text-xs font-mono text-accent w-4 text-right">3.</span><span class="text-lg font-semibold text-text-primary">Paste together</span></div>
              </div>
              <p class="mt-5 text-text-secondary text-base">No back-and-forth. Select multiple clips, paste them all at once.</p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .journey-tab {
    font-size: 0.875rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    cursor: pointer;
    transition: color 0.2s, background-color 0.2s;
    color: var(--color-text-muted);
    background: rgba(255, 255, 255, 0.05);
  }
  .journey-tab:hover {
    color: var(--color-text-secondary);
  }

  .journey-panel {
    display: none;
  }

  .peer\/video:checked ~ div .journey-panel[data-journey="video"] { display: block; }
  .peer\/gif:checked ~ div .journey-panel[data-journey="gif"] { display: block; }
  .peer\/text:checked ~ div .journey-panel[data-journey="text"] { display: block; }
  .peer\/multi:checked ~ div .journey-panel[data-journey="multi"] { display: block; }

  .peer\/video:checked ~ div .journey-tab[for="j-video"],
  .peer\/gif:checked ~ div .journey-tab[for="j-gif"],
  .peer\/text:checked ~ div .journey-tab[for="j-text"],
  .peer\/multi:checked ~ div .journey-tab[for="j-multi"] {
    background: rgba(212, 113, 94, 0.15);
    color: var(--color-accent);
  }
</style>
