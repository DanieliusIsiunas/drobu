---
import { DOWNLOAD_URL } from "../config";

const navLinks = [
  { label: "Features", href: "/#features" },
  { label: "Compare", href: "/compare" },
  { label: "Privacy", href: "/#privacy" },
];
---

<header class="fixed top-0 left-0 right-0 z-40 backdrop-blur-lg bg-bg-primary/80 border-b border-white/5">
  <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-text-primary font-semibold text-lg tracking-tight">
      <img src="/drobule-small.png" alt="" width="24" height="24" class="inline-block" />
      <span>Drobu</span>
    </a>

    <div class="hidden md:flex items-center gap-7">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200"
        >
          {label}
        </a>
      ))}
      <a
        href={DOWNLOAD_URL}
        download="Drobu.dmg"
        id="nav-download"
        class="js-app-download inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg bg-accent hover:bg-accent-hover text-white text-sm font-semibold transition-colors duration-200"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        <span class="download-label">Download</span>
      </a>
    </div>
  </nav>
</header>

<script>
  // Platform guard for every app-download button site-wide: a non-macOS
  // visitor should never be handed a .dmg they cannot use.
  const isMac =
    navigator.platform?.includes("Mac") ||
    (navigator as any).userAgentData?.platform === "macOS";
  if (!isMac) {
    document.querySelectorAll(".js-app-download").forEach((el) => {
      const label = el.querySelector(".download-label");
      if (label) label.textContent = "macOS only";
      el.classList.add("opacity-50", "pointer-events-none", "cursor-not-allowed");
    });
  }
</script>
