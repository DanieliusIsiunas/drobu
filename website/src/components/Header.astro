---
const navLinks = [
  { label: "Features", href: "/#features" },
  { label: "Compare", href: "/compare" },
  { label: "Privacy", href: "/#privacy" },
  { label: "Download", href: "/#download" },
];
---

<header class="fixed top-0 left-0 right-0 z-40 backdrop-blur-lg bg-bg-primary/80 border-b border-white/5">
  <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-text-primary font-semibold text-lg tracking-tight">
      <img src="/drobule-small.png" alt="" width="24" height="24" class="inline-block" />
      <span>Drobu</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors duration-200"
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>
