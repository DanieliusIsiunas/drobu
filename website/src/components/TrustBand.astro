---
const items = [
  {
    label: "Local-first",
    detail: "Clipboard stays on your Mac, no tracking",
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />',
  },
  {
    label: "Passwords ignored",
    detail: "1Password and concealed items are never stored",
    icon: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />',
  },
  {
    label: "Bought once",
    detail: "$14.99, not a subscription",
    icon: '<path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" /><line x1="7" y1="7" x2="7.01" y2="7" />',
  },
];
---

<section id="privacy" class="py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <p class="text-xs uppercase tracking-widest text-text-muted mb-4 font-medium">
      Private. Yours. Bought once.
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-5">
      Everything stays on your Mac.
    </h2>
    <p class="text-text-secondary text-lg leading-relaxed max-w-2xl mx-auto">
      No account, no tracking, and passwords are never stored. Drobu is a one-time
      <span class="text-accent font-semibold">$14.99</span>, not a subscription. Buy it, keep it.
    </p>

    <div class="mt-10 grid grid-cols-1 sm:grid-cols-3 gap-6 text-left">
      {items.map((item) => (
        <div class="flex items-start gap-3">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0 mt-0.5" aria-hidden="true" set:html={item.icon} />
          <div>
            <p class="text-sm font-semibold text-text-primary">{item.label}</p>
            <p class="text-xs text-text-muted leading-relaxed">{item.detail}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="mt-10 text-sm text-text-muted">macOS 14 and later</p>
  </div>
</section>
