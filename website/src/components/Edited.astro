---
import Showcase from "./Showcase.astro";

const points = [
  "Preview any item the instant you select it, no opening needed",
  "Crop a screenshot or image to just the right frame",
  "Trim a GIF or video down to the part that matters",
  "Built in, so there is no round trip to Preview or QuickTime",
];
---

<section id="features" class="py-24 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Visual: real capture of cropping an image in Drobu (first on desktop, second on mobile) -->
    <Showcase
      src="/media/image-crop.mp4"
      poster="/media/image-crop-poster.jpg"
      alt="Cropping a captured image inside Drobu, then pasting it"
      width={1366}
      height={852}
      class="md:order-1 order-2"
    />

    <!-- Copy -->
    <div class="md:order-2 order-1">
      <p class="text-xs uppercase tracking-widest text-accent mb-4 font-medium">Edited</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-5 leading-tight">
        Fix it before it lands.
      </h2>
      <p class="text-text-secondary text-lg leading-relaxed mb-7">
        Crop a screenshot down to just the right frame. Trim a recording to the moment that matters. Drobu has a built-in editor, so you go straight from capture to paste without a detour through another app.
      </p>
      <ul class="space-y-3">
        {points.map((p) => (
          <li class="flex items-start gap-3 text-text-secondary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0 mt-0.5" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" />
            </svg>
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
