---
import { STRIPE_CHECKOUT_URL } from "../config";
---

<section id="download" class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
      Try Drobu today.
    </h2>
    <p class="text-text-secondary text-lg mb-10">
      Record your screen and paste it. No QuickTime. No exports. Just Drobu.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a
        href={STRIPE_CHECKOUT_URL}
        class="inline-flex items-center gap-2 px-8 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-lg"
      >
        Start free trial
      </a>
    </div>

    <div class="text-sm text-text-muted space-y-2">
      <p>Requires macOS 14 (Sonoma) or later &middot; Version 1.2</p>
      <details class="inline-block text-left max-w-md mx-auto">
        <summary class="cursor-pointer hover:text-text-secondary transition-colors">
          macOS shows a security warning?
        </summary>
        <p class="mt-2 text-text-muted leading-relaxed">
          Right-click the app, choose "Open", then click "Open" in the dialog. This only happens once because Drobu isn't notarized yet.
        </p>
      </details>
    </div>
  </div>
</section>
