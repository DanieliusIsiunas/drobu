---
import { DOWNLOAD_URL } from "../config";
---

<section id="download" class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
      Try Drobu today.
    </h2>
    <p class="text-text-secondary text-lg mb-10">
      Record your screen and paste it. No QuickTime. No exports. Just Drobu.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a
        href={DOWNLOAD_URL}
        download="Drobu.dmg"
        class="inline-flex items-center gap-2 px-8 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-lg"
      >
        Download Free Trial
      </a>
    </div>

    <div class="text-sm text-text-muted space-y-2">
      <p>Free for 14 days, then $14.99 one-time &middot; macOS 14+ &middot; Version 1.3</p>
      <p class="text-xs max-w-md mx-auto">
        First launch: macOS may show "Apple could not verify". Open <strong class="text-text-secondary">System Settings &rarr; Privacy &amp; Security</strong> and click <strong class="text-text-secondary">Open Anyway</strong>. One-time.
      </p>
    </div>
  </div>
</section>
