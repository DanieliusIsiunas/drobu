---
import { DOWNLOAD_URL } from "../config";
---

<section id="download" class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">
      Try Drobu today.
    </h2>
    <p class="text-text-secondary text-lg mb-10">
      The clipboard you can edit. Capture text, images, GIFs, files, or your screen, then crop, trim, and paste it back. No exports, no cleanup.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a
        href={DOWNLOAD_URL}
        download="Drobu.dmg"
        class="js-app-download inline-flex items-center gap-2 px-8 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-lg"
      >
        <span class="download-label">Download Free Trial</span>
      </a>
    </div>

    <div class="text-sm text-text-muted space-y-2">
      <p class="text-text-secondary">Free for 14 days. No credit card, no account.</p>
      <p>Then $14.99 once, no subscription &middot; macOS 14+</p>
    </div>
  </div>
</section>
