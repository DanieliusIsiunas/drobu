---
// Homepage highlight vs the macOS 26 (Tahoe) Spotlight clipboard. The full
// side-by-side lives at /compare/drobu-vs-spotlight; this is the condensed
// version for the common "why not just use the free built-in one?" question.
// Claims are grounded in verified facts: 7-day max retention, formatting
// stripped from text, ~16k char cap, no source-app tracking, no capture,
// macOS 26 only. Stated as defensible ceilings so they stay accurate across
// Tahoe point releases.
const spotlightLimits = [
  "Clips cleared within 7 days",
  "Strips formatting from text",
  "Caps clips at ~16,000 characters",
  "No source-app tracking",
  "No screen, GIF, or video capture",
  "Requires macOS 26",
];

const drobuWins = [
  "Keeps clips for up to a year",
  "Full-text search of your history",
  "Source app on every clip",
  "Screen to GIF and video, with crop and trim",
  "Paste anything with one keystroke",
  "Works on macOS 14 and later",
];
---

<section id="spotlight" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-xs uppercase tracking-widest text-text-muted mb-4">
        macOS 26 Spotlight clipboard?
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
        macOS 26 added a clipboard. <span class="text-accent">Drobu is the one you'll actually use.</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      <!-- Spotlight clipboard -->
      <div class="p-6 rounded-2xl border border-white/5 bg-bg-card">
        <h3 class="text-lg font-semibold text-text-secondary mb-4">Spotlight clipboard</h3>
        <ul class="space-y-3">
          {spotlightLimits.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-secondary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-muted shrink-0 mt-0.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10" /><path d="m15 9-6 6" /><path d="m9 9 6 6" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Drobu -->
      <div class="p-6 rounded-2xl border border-accent/30 bg-bg-card">
        <h3 class="text-lg font-semibold text-text-primary mb-4">Drobu</h3>
        <ul class="space-y-3">
          {drobuWins.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0 mt-0.5" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="text-center mt-10">
      <a href="/compare/drobu-vs-spotlight" class="text-sm font-medium text-accent hover:underline">
        See the full Drobu vs Spotlight comparison &rarr;
      </a>
    </div>
  </div>
</section>
