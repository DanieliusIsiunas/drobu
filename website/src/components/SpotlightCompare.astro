---
// Positioning vs the macOS 26 (Tahoe) Spotlight clipboard history.
// Claims are grounded in verified facts (8h default / 7-day max retention,
// plain-text only, ~16k char cap, no search/pinning/source-tracking/capture;
// requires macOS 26). Kept conservative ("a few hours") so it stays accurate
// as Apple iterates retention.
const spotlightLimits = [
  "Recent items expire in hours (7 days at most)",
  "Plain text only — formatting is stripped",
  "No full-text search across your history",
  "No record of which app a clip came from",
  "No screen, GIF, or video capture",
  "Requires macOS 26 — nothing on macOS 14 or 15",
];

const drobuWins = [
  "Keep your full history, no forced expiry",
  "FTS5 full-text search — results as you type",
  "Source app tracked on every clip",
  "Screen to GIF & video, with crop and trim",
  "Paste anything with one keystroke",
  "Works on macOS 14 (Sonoma) and later",
];
---

<section id="spotlight" class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-xs uppercase tracking-widest text-text-muted mb-4">
        macOS 26 Spotlight clipboard?
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
        macOS 26 added a clipboard. <span class="text-accent">Drobu is the one you'll actually use.</span>
      </h2>
      <p class="mt-6 text-text-secondary text-lg max-w-2xl mx-auto">
        Tahoe's Spotlight clipboard keeps recent text and images for a few hours, then drops them. Drobu keeps everything — searchable, editable, one keystroke away, on macOS 14 too.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4">
      <!-- Spotlight clipboard -->
      <div class="p-6 rounded-2xl border border-white/5 bg-bg-card">
        <h3 class="text-lg font-semibold text-text-secondary mb-4">Spotlight clipboard</h3>
        <ul class="space-y-3">
          {spotlightLimits.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-secondary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-muted shrink-0 mt-0.5" aria-hidden="true">
                <circle cx="12" cy="12" r="10" /><path d="m15 9-6 6" /><path d="m9 9 6 6" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Drobu -->
      <div class="p-6 rounded-2xl border border-accent/30 bg-bg-card">
        <h3 class="text-lg font-semibold text-text-primary mb-4">Drobu</h3>
        <ul class="space-y-3">
          {drobuWins.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0 mt-0.5" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
