---
import MacWindow from "./MacWindow.astro";

const points = [
  "Copy anything, it is saved the moment you do",
  "Record a region of your screen to GIF or video",
  "Up to five minutes, no QuickTime, no leftover files",
];
---

<section id="features" class="py-24 px-6">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
    <!-- Copy -->
    <div>
      <p class="text-xs uppercase tracking-widest text-accent mb-4 font-medium">Captured</p>
      <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-5 leading-tight">
        Everything you copy. Plus your whole screen.
      </h2>
      <p class="text-text-secondary text-lg leading-relaxed mb-7">
        Copy text, links, images, or files and Drobu keeps them automatically. Need something that is not on your clipboard yet? Record any part of your screen as a GIF or video, straight from the menu bar.
      </p>
      <ul class="space-y-3">
        {points.map((p) => (
          <li class="flex items-start gap-3 text-text-secondary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent shrink-0 mt-0.5" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" />
            </svg>
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Visual: what gets captured -->
    <MacWindow title="Drobu">
      <div class="bg-bg-primary p-2 space-y-1">
        <!-- New screen recording, highlighted -->
        <div class="flex items-center gap-3 px-2.5 py-2 rounded-lg bg-accent/10 border border-accent/20">
          <div class="w-8 h-8 rounded bg-accent/20 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-accent" aria-hidden="true">
              <polygon points="23 7 16 12 23 17 23 7" /><rect x="1" y="5" width="15" height="14" rx="2" ry="2" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-text-primary truncate">Screen recording</p>
            <p class="text-[11px] text-text-muted">Just now</p>
          </div>
          <span class="text-[10px] px-2 py-0.5 rounded-full bg-accent/20 text-accent font-medium shrink-0">GIF &middot; 0:04</span>
        </div>
        <!-- Link -->
        <div class="flex items-center gap-3 px-2.5 py-2 rounded-lg">
          <div class="w-8 h-8 rounded bg-[#1a8cff] flex items-center justify-center shrink-0">
            <span class="text-[11px] text-white font-bold">S</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-text-secondary truncate">developer.apple.com/sf-symbols</p>
            <p class="text-[11px] text-text-muted">Safari</p>
          </div>
        </div>
        <!-- Note -->
        <div class="flex items-center gap-3 px-2.5 py-2 rounded-lg">
          <div class="w-8 h-8 rounded bg-[#f59e0b] flex items-center justify-center shrink-0">
            <span class="text-[11px] text-white font-bold">N</span>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-text-secondary truncate">Meeting notes: Q2 planning</p>
            <p class="text-[11px] text-text-muted">Notes</p>
          </div>
        </div>
        <!-- Image -->
        <div class="flex items-center gap-3 px-2.5 py-2 rounded-lg">
          <div class="w-8 h-8 rounded bg-gradient-to-br from-blue-500/40 to-purple-500/40 flex items-center justify-center shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-white/80" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="m21 15-5-5L5 21" />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-text-secondary truncate">Screenshot</p>
            <p class="text-[11px] text-text-muted">Finder</p>
          </div>
        </div>
      </div>
    </MacWindow>
  </div>
</section>
