---
interface Props {
  title?: string;
  class?: string;
}

const { title = "", class: className = "" } = Astro.props;
---

<div class:list={["rounded-xl overflow-hidden border border-white/10 bg-bg-elevated shadow-2xl", className]}>
  <!-- Title bar -->
  <div class="flex items-center gap-2 px-4 py-3 bg-white/5 border-b border-white/5">
    <div class="flex gap-1.5">
      <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
      <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
      <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
    </div>
    {title && (
      <span class="text-xs text-text-muted ml-2">{title}</span>
    )}
  </div>
  <!-- Window content -->
  <div class="relative">
    <slot />
  </div>
</div>
