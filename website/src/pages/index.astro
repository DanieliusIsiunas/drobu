---
import Landing from "../layouts/Landing.astro";
---

<Landing>
  <main id="main" class="flex flex-col items-center justify-center min-h-screen px-6">
    <h1 class="text-5xl font-bold tracking-tight text-text-primary">
      Your clipboard, with a memory.
    </h1>
    <p class="mt-4 text-lg text-text-secondary max-w-lg text-center">
      Drobu keeps everything you copy and lets you find it instantly.
    </p>
  </main>
</Landing>
