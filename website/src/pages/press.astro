---
import Landing from "../layouts/Landing.astro";

const title = "Press & Media Kit | Drobu";
const description =
  "Press and media kit for Drobu, the macOS clipboard manager you can edit: logos, screenshots, a demo video, and the facts. Free review licenses for writers.";

const facts = [
  { label: "What it is", value: "macOS clipboard manager with built-in editing and screen capture" },
  { label: "Platform", value: "macOS 14 (Sonoma) and later, Intel and Apple Silicon" },
  { label: "Price", value: "$14.99 one-time, 14-day free trial (no card)" },
  { label: "Privacy", value: "100% local, no account, no tracking, passwords ignored" },
  { label: "Maker", value: "Danielius Isiūnas (solo indie)" },
  { label: "Contact", value: "support@drobu.app" },
];

const isNot = [
  "Not a subscription. It is a one-time $14.99 purchase.",
  "Not a cloud or sync service. It is local-only; nothing you copy is uploaded.",
  "Not account-based. You can use it without signing up for anything.",
  "Not the Mac App Store build. It ships as a notarized direct download.",
  "Not Drobu Media, Drobių Namai, or any canvas-print or insurance company. Drobu is the macOS clipboard manager at drobu.app.",
];

const shots = [
  { src: "/press/screenshot-1-interface.jpg", alt: "The Drobu clipboard panel with search, type filters, and a preview" },
  { src: "/press/screenshot-2-edit.jpg", alt: "Cropping a captured image in place inside Drobu" },
  { src: "/press/screenshot-3-multipaste.jpg", alt: "Selecting several clips to paste them together" },
];
---

<Landing title={title} description={description}>
  <main id="main" class="max-w-3xl mx-auto px-6 pt-28 pb-24">
    <header class="mb-12">
      <p class="text-xs uppercase tracking-widest text-accent mb-4 font-medium">Press &amp; media kit</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-text-primary mb-5">
        Writing about Drobu?
      </h1>
      <p class="text-lg text-text-secondary leading-relaxed">
        Everything you need in one place: logos, screenshots, a demo video, and the plain facts. Writing a review or a roundup? Email <a href="mailto:support@drobu.app" class="text-accent hover:underline">support@drobu.app</a> and I will send a free license, no strings.
      </p>
    </header>

    <!-- Download kit -->
    <section class="mb-14">
      <a
        href="/press/drobu-press-kit.zip"
        download
        class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200"
      >
        Download the full kit (ZIP)
      </a>
      <p class="mt-3 text-sm text-text-muted">App icon, screenshots, and a description. Demo video: <a href="/media/main-interface.mp4" class="text-accent hover:underline">main-interface.mp4</a>.</p>
    </section>

    <!-- The pitch -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-text-primary mb-4">In one line</h2>
      <p class="text-text-secondary leading-relaxed mb-6"><strong class="text-text-primary">The clipboard you can edit.</strong></p>
      <h2 class="text-2xl font-bold text-text-primary mb-4">In a paragraph</h2>
      <p class="text-text-secondary leading-relaxed">
        Drobu is a macOS clipboard manager built around one idea: the clipboard should be where the work happens, not just where things sit. Everything you copy lands in one searchable history, text, links, images, GIFs, files, even a region of your screen you record on the spot. You crop a screenshot, trim a clip, or clean up copied text right in the panel, then paste one item or a whole stack with a single keystroke. No app switching, no exports. It runs entirely on your Mac, with no account and no tracking, and your clipboard never leaves your device.
      </p>
    </section>

    <!-- Facts -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-text-primary mb-6">Facts</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-white/5 rounded-2xl overflow-hidden border border-white/5">
        {facts.map((f) => (
          <div class="bg-bg-card px-5 py-4">
            <p class="text-[11px] uppercase tracking-wide text-text-muted mb-1">{f.label}</p>
            <p class="text-sm text-text-primary">{f.value}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- What it is NOT (entity disambiguation, honest framing) -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-text-primary mb-4">What Drobu is not</h2>
      <ul class="space-y-3">
        {isNot.map((item) => (
          <li class="flex items-start gap-3 text-text-secondary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-text-muted shrink-0 mt-0.5" aria-hidden="true">
              <circle cx="12" cy="12" r="10" /><path d="m15 9-6 6" /><path d="m9 9 6 6" />
            </svg>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- Screenshots -->
    <section class="mb-14">
      <h2 class="text-2xl font-bold text-text-primary mb-6">Screenshots</h2>
      <div class="grid gap-4">
        {shots.map((s) => (
          <figure class="m-0 rounded-xl overflow-hidden border border-white/10">
            <img src={s.src} alt={s.alt} width="1270" height="760" loading="lazy" decoding="async" class="block w-full h-auto" />
          </figure>
        ))}
      </div>
    </section>

    <section class="text-center border-t border-white/5 pt-12">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">Questions?</h2>
      <p class="text-text-secondary">Email <a href="mailto:support@drobu.app" class="text-accent hover:underline">support@drobu.app</a> and I will get back to you.</p>
    </section>
  </main>
</Landing>
