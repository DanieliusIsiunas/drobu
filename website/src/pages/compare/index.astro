---
import Landing from "../../layouts/Landing.astro";
import { DOWNLOAD_URL } from "../../config";
import { comparisons, masterMatrix } from "../../data/comparisons";

const title = "Drobu vs Maccy, Paste, CleanShot, Raycast & Spotlight";
const description =
  "How Drobu compares to Maccy, Paste, CleanShot X, Raycast, and the macOS Spotlight clipboard on history, capture, editing, pricing, and privacy for Mac.";

const products = ["drobu", "maccy", "paste", "cleanshot", "raycast", "spotlight"] as const;
const productLabels: Record<string, string> = {
  drobu: "Drobu",
  maccy: "Maccy",
  paste: "Paste",
  cleanshot: "CleanShot X",
  raycast: "Raycast",
  spotlight: "Spotlight",
};
---

<Landing title={title} description={description}>
  <main id="main" class="max-w-4xl mx-auto px-6 pt-28 pb-24">
    <header class="text-center mb-16">
      <p class="text-xs uppercase tracking-widest text-text-muted mb-4">Comparisons</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-text-primary">
        How Drobu compares
      </h1>
      <p class="mt-6 text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
        Drobu is the clipboard you can edit. It's the only one of these where you can capture, edit, and paste back on one surface: searchable clipboard history, screen recording, plus inline crop and trim for images, GIFs, and video. One-time price, fully local. Here's the honest side-by-side, including where the others win.
      </p>
    </header>

    <!-- At-a-glance master table -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-text-primary mb-6 text-center">At a glance</h2>
      <div class="overflow-x-auto rounded-2xl border border-white/5 bg-bg-card">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-white/10">
              <th scope="col" class="text-left font-medium text-text-muted px-4 py-3">Feature</th>
              {products.map((p) => (
                <th scope="col" class={`text-left px-4 py-3 ${p === "drobu" ? "font-semibold text-accent" : "font-medium text-text-secondary"}`}>{productLabels[p]}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {masterMatrix.map((row) => (
              <tr class="border-b border-white/5 last:border-0 align-top">
                <th scope="row" class="text-left font-normal text-text-muted px-4 py-3">{row.dimension}</th>
                <td class="px-4 py-3 text-text-primary font-medium">{row.drobu}</td>
                <td class="px-4 py-3 text-text-secondary">{row.maccy}</td>
                <td class="px-4 py-3 text-text-secondary">{row.paste}</td>
                <td class="px-4 py-3 text-text-secondary">{row.cleanshot}</td>
                <td class="px-4 py-3 text-text-secondary">{row.raycast}</td>
                <td class="px-4 py-3 text-text-secondary">{row.spotlight}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-text-muted text-center">Competitor details verified June 2026. Prices can change, so check each vendor for the latest.</p>
    </section>

    <!-- Per-comparison cards -->
    <section class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {comparisons.map((c) => (
        <a href={`/compare/${c.slug}`} class="group p-6 rounded-2xl border border-white/5 bg-bg-card hover:border-white/10 hover:-translate-y-1 transition-all duration-300">
          <h2 class="text-lg font-semibold text-text-primary mb-2">{c.h1}</h2>
          <p class="text-sm text-text-secondary leading-relaxed mb-3">{c.priceLine}</p>
          <span class="text-sm text-accent group-hover:underline">Read the comparison →</span>
        </a>
      ))}
    </section>

    <section class="text-center border-t border-white/5 pt-12">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">Try Drobu free for 14 days.</h2>
      <p class="text-text-secondary mb-8">$14.99 once, then it's yours. No subscription, no account.</p>
      <a
        href={DOWNLOAD_URL}
        download="Drobu.dmg"
        class="js-app-download inline-flex items-center gap-2 px-8 py-4 bg-accent hover:bg-accent-hover text-white font-semibold rounded-xl transition-colors duration-200 text-lg"
      >
        <span class="download-label">Download Free Trial</span>
      </a>
    </section>
  </main>
</Landing>
