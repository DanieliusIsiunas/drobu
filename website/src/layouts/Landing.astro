---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { PRODUCT_DESCRIPTION } from "../data/product";
import { ANALYTICS_ENABLED } from "../config";

interface Props {
  title?: string;
  description?: string;
  /** When true, emit `noindex` and suppress the product JSON-LD (used on
   *  thin/transient pages: /thank-you, /404). */
  noindex?: boolean;
  /** Extra JSON-LD object(s) emitted in <head> on indexable pages, e.g. the
   *  FAQPage schema on /faq. */
  extraSchema?: object | object[];
}

const {
  title = "Drobu | Mac Clipboard Manager You Can Edit",
  description = "Drobu is a Mac clipboard manager: capture text, images, GIFs, and screen recordings, edit and search your clipboard history, then paste with one keystroke. $14.99 once.",
  noindex = false,
  extraSchema,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og-image.png", Astro.site);

// Product-level copy for structured data + share previews. Kept independent
// of the per-page `description` so the schema/alt stay accurate on every page
// (e.g. /privacy, /terms) rather than inheriting that page's description.
// PRODUCT_DESCRIPTION (the canonical "what is Drobu" sentence) is shared from
// ../data/product so the JSON-LD, the FAQ lead, and llms.txt stay in lockstep.
const OG_IMAGE_ALT =
  "Drobu: the macOS clipboard manager you can edit";

const ORG_ID = "https://drobu.app/#drobu";

// One JSON-LD @graph: an Organization (with sameAs entity anchors + logo) and
// the SoftwareApplication that points back to it as publisher.
const productSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": ORG_ID,
      name: "Drobu",
      url: "https://drobu.app",
      logo: "https://drobu.app/drobule.png",
      description: PRODUCT_DESCRIPTION,
      // Entity-disambiguation anchors. Add AlternativeTo / Product Hunt /
      // Crunchbase / Wikidata URLs here as those profiles go live.
      sameAs: ["https://github.com/DanieliusIsiunas/drobu"],
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://drobu.app/#app",
      name: "Drobu",
      url: "https://drobu.app",
      operatingSystem: "macOS 14.0 or later",
      applicationCategory: "UtilitiesApplication",
      applicationSubCategory: "Clipboard Manager",
      downloadUrl:
        "https://github.com/DanieliusIsiunas/drobu/releases/latest/download/Drobu.dmg",
      image: ogImage.href,
      screenshot: ogImage.href,
      featureList: [
        "Clipboard history",
        "In-place text editing",
        "Image and GIF cropping",
        "GIF and video trimming",
        "Full-text search",
        "Screen recording",
        "GIF capture",
        "One-keystroke paste",
        "Multi-select paste",
        "Slash commands",
        "Source-app tracking",
        "Local-only storage",
      ],
      offers: {
        "@type": "Offer",
        price: "14.99",
        priceCurrency: "USD",
        availability: "https://schema.org/InStock",
        url: "https://drobu.app/buy",
      },
      author: {
        "@type": "Person",
        name: "Danielius Isiūnas",
        url: "https://drobu.app",
      },
      publisher: { "@id": ORG_ID },
      description: PRODUCT_DESCRIPTION,
    },
  ],
};
---

<!doctype html>
<html lang="en" class="bg-bg-primary text-text-primary">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Canonical only on indexable pages — a noindex page (e.g. /404) has no
        meaningful canonical URL, and on the 404 it would point at /404/, which
        GitHub Pages never serves. */}
    {!noindex && <link rel="canonical" href={canonicalURL} />}
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Drobu" />
    <meta property="og:locale" content="en_US" />
    {!noindex && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={OG_IMAGE_ALT} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={OG_IMAGE_ALT} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Privacy-respecting, cookieless analytics (Umami Cloud). Gated on
        ANALYTICS_ENABLED so dev builds emit NOTHING here (and the privacy page's
        "no tracking scripts" claim stays true off-prod). No first-party proxy:
        loaded from the vendor domain so a visitor's blocker works. Download
        buttons are tagged with data-umami-event="Download" so Umami's OWN click
        handler records the event — it preventDefaults the link, sends the beacon,
        then proceeds to the download, which a manual track() call on a navigating
        link does not reliably do. The tag is applied on DOMContentLoaded so it
        covers every .js-app-download button without editing each one.

        The body MUST go through set:html: a {`...`} expression as a child of a
        <script is:inline> is emitted VERBATIM (braces + backticks and all), so
        the browser runs a bare block containing a discarded string and the
        addEventListener never fires. set:html injects the evaluated string as the
        raw script body. */}
    {
      ANALYTICS_ENABLED && (
        <Fragment>
          <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="26adbb73-1a3c-410f-a601-6b208a71ad42" />
          <script
            is:inline
            set:html={`document.addEventListener("DOMContentLoaded", function () {
  document.querySelectorAll(".js-app-download").forEach(function (el) {
    el.setAttribute("data-umami-event", "Download");
  });
});`}
          />
        </Fragment>
      )
    }

    <!-- Structured data: product schema only on indexable pages -->
    {
      !noindex && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(productSchema)}
        />
      )
    }
    {
      !noindex && extraSchema &&
        (Array.isArray(extraSchema) ? extraSchema : [extraSchema]).map((s) => (
          <script type="application/ld+json" set:html={JSON.stringify(s)} />
        ))
    }
  </head>
  <body class="font-sans antialiased bg-bg-primary text-text-primary min-h-screen">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg">
      Skip to content
    </a>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
