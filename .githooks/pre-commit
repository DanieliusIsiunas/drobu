#!/bin/bash
# Run tests before every commit. Fails the commit if tests fail.
# Skip with: git commit --no-verify (use sparingly)

echo "Running swift test..."
swift test --quiet 2>&1
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Tests failed. Fix before committing."
    echo "   Run 'swift test' to see details."
    echo "   Skip with --no-verify if you must (e.g., docs-only change)."
    exit 1
fi
