# Template for supabase/functions/.env.local (gitignored — never commit real
# values). Production values go in via `supabase secrets set`, NOT this file.
#
# Local dev shape: EXPECTED_LIVEMODE=false and PAYMENT_LINK_ID unset, so
# `stripe trigger` fixtures (livemode:false, payment_link:null) pass the
# gates. Production: EXPECTED_LIVEMODE=true and the exact plink_... pin.

STRIPE_WEBHOOK_SECRET=whsec_replace_me
EXPECTED_LIVEMODE=false
PAYMENT_LINK_ID=
AMOUNT_FLOOR=1000

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=license@drobu.app
SMTP_PASSWORD=replace_me
MAIL_FROM=Drobu <license@drobu.app>
MAIL_REPLY_TO=support@drobu.app
