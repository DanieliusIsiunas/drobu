# Template for supabase/functions/.env.local (gitignored — never commit real
# values). Production values go in via `supabase secrets set`, NOT this file.
#
# Local dev shape: EXPECTED_LIVEMODE=false and PAYMENT_LINK_ID unset, so
# `stripe trigger` fixtures (livemode:false, payment_link:null) pass the
# gates. Production: EXPECTED_LIVEMODE=true and the exact plink_... pin.

STRIPE_WEBHOOK_SECRET=whsec_replace_me
EXPECTED_LIVEMODE=false
PAYMENT_LINK_ID=
AMOUNT_FLOOR=1000

# activate-device function: the PUBLIC license key, same base64 string as
# Info.plist DrobuLicensePublicKey. PUBLIC key only — the private signing key
# never leaves the dev Keychain. The function verifies activation requests
# against this so a leaked payload_hex alone can't burn a stranger's seats.
DROBU_LICENSE_PUBLIC_KEY=uvHoJNNeLFAv671r15WGSDUxRNUUWwpOaJKqgUkEDSc=

# support@ is the single Hostinger mailbox — use an App Password generated
# in hPanel (Emails -> mailbox menu -> App passwords), never the main
# mailbox password.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=support@drobu.app
SMTP_PASSWORD=replace_me_with_app_password
MAIL_FROM=Drobu <support@drobu.app>
MAIL_REPLY_TO=support@drobu.app
